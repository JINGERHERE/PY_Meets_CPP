#pragma once
#include <vector>
#include <set>
#include <algorithm>

class IntervalCounter
{
public:
    struct Interval
    {
        long long start;
        long long end;
        // 保持原来的排序逻辑，按区间起点排序
        bool operator<(const Interval &other) const
        {
            return start < other.start;
        }
    };

    IntervalCounter(long long start = 0, long long step = 1)
        : current(start), step(step) {}

    long long next()
    {
        jump_if_needed();
        long long result = current;

        // 直接合并到区间树中，不再存入 history_log
        add_single_value(result);

        current += step;
        jump_if_needed();
        return result;
    }

    void add_history(const std::vector<long long> &values)
    {
        for (auto v : values)
        {
            add_single_value(v);
        }
        jump_if_needed();
    }

    // --- 核心修改：获取历史记录的方式 ---

    // 方式 A：返回合并后的区间（极其节省内存和传输带宽）
    // 结果如：[(1, 3), (5, 7), (15, 17)]
    std::vector<std::pair<long long, long long>> get_interval_history() const
    {
        std::vector<std::pair<long long, long long>> res;
        for (const auto &i : intervals)
        {
            res.push_back({i.start, i.end});
        }
        return res;
    }

    // 方式 B：如果 Python 端一定要一个个数字，我们动态生成（时间换空间）
    std::vector<long long> get_full_history() const
    {
        std::vector<long long> full_history;
        for (const auto &i : intervals)
        {
            for (long long v = i.start; v <= i.end; v += step)
            {
                full_history.push_back(v);
            }
        }
        return full_history;
    }

private:
    long long current;
    long long step;
    std::set<Interval> intervals; // 这已经是你的“压缩蓄水池”了

    void jump_if_needed()
    {
        while (true)
        {
            // 查找第一个起点大于当前值的区间
            auto it = intervals.upper_bound({current, current});
            if (it != intervals.begin())
            {
                auto prev = std::prev(it);
                // 如果当前值落在前一个区间内，直接跳到区间末尾之后
                if (current >= prev->start && current <= prev->end)
                {
                    current = prev->end + step;
                    continue;
                }
            }
            break;
        }
    }

    void add_single_value(long long v)
    {
        long long new_start = v;
        long long new_end = v;

        // 寻找插入位置
        auto it = intervals.lower_bound({new_start, new_end});

        // 向后合并：检查后面相连或重叠的区间
        while (it != intervals.end() && it->start <= new_end + step)
        {
            new_end = std::max(new_end, it->end);
            it = intervals.erase(it);
        }

        // 向前合并：检查前面相连或重叠的区间
        if (it != intervals.begin())
        {
            auto prev = std::prev(it);
            if (prev->end + step >= new_start)
            {
                new_start = std::min(new_start, prev->start);
                new_end = std::max(new_end, prev->end);
                intervals.erase(prev);
            }
        }

        intervals.insert({new_start, new_end});
    }
};